# Flutter/Dart ignores (app lives in frontend/)
frontend/.dart_tool/
frontend/.packages
frontend/.pub-cache/
frontend/.pub/
frontend/build/
# keep the precompiled web bundle that Vercel serves (see vercel.json)
!frontend/build/web/

# GitLab CI runner working directory (local runner artifacts, not source)
/builds/

# Local SQLite test DBs and coverage artifacts
backend/*.db
*.db
.coverage
backend/.coverage

# Tool caches
.ruff_cache/
backend/.ruff_cache/
.mypy_cache/
backend/.mypy_cache/

# Android ignores
.gradle/
local.properties
*.keystore
*.jks

# iOS ignores
Pods/
.generated/
*.moved-aside

# Web ignores
.web_cache/

# IDE ignores
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db

# Env ignores
.env*
!.env.example
.vercel

# Local server logs
*.log
