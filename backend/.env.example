# Database connection
# For local dev without Docker, use SQLite (recommended for local testing):
DATABASE_URL=sqlite:///./roadside_help.db
# For PostgreSQL with Docker Compose:
# DATABASE_URL=postgresql+psycopg://postgres:root@localhost:5433/roadside_help

# Authentication & Security
JWT_SECRET=dev-insecure-secret-change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TTL_MINUTES=60
REFRESH_TTL_DAYS=30

# Optional: Google OAuth client ID for ID-token verification
# Leave unset to enable Google mock mode (dev/testing)
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Optional: Twilio SMS for real OTP delivery
# Leave all unset to enable SMS mock mode (dev/testing shows code in response)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=*

# Seed location for demo helpers (Hyderabad center coordinates by default)
SEED_CENTER_LAT=17.4239
SEED_CENTER_LNG=78.4738
