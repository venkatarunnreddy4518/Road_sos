{
  "version": 2,
  "buildCommand": "",
  "installCommand": "",
  "outputDirectory": "frontend/build/web",
  "framework": null,
  "routes": [
    {
      "src": "/$",
      "dest": "/welcome.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" }
      ]
    }
  ]
}
