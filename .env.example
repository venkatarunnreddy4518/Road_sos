# ==========================================
# Backend API Config (FastAPI)
# ==========================================
# Database connection (Use SQLite default or set your PostgreSQL connection URL)
DATABASE_URL=sqlite:///./roadside_help.db

# Auth security settings
JWT_SECRET=your-secure-random-jwt-secret-string
JWT_ALGORITHM=HS256
ACCESS_TTL_MINUTES=60
REFRESH_TTL_DAYS=30

# CORS settings (allowed origins, comma-separated)
CORS_ORIGINS=*

# Seed default location settings (places mock helpers near this coordinate)
SEED_CENTER_LAT=17.4239
SEED_CENTER_LNG=78.4738

# Twilio Configuration (Optional, for SMS OTP delivery)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Google Client ID (Optional, for Google Sign-In)
# GOOGLE_CLIENT_ID=web-id.apps.googleusercontent.com,android-id.apps.googleusercontent.com

# ==========================================
# Frontend Config (Flutter Web)
# ==========================================
# When building the frontend, pass your live backend URL via dart-define:
# flutter build web --release --dart-define=API_BASE_URL=https://your-backend-api-url.onrender.com
